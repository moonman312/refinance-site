{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "refinancehoteldebt.com"
        }
      ],
      "destination": "https://hotelloanrefinance.com/$1?ref=refinancehoteldebt.com",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "refinancehotel.com"
        }
      ],
      "destination": "https://hotelloanrefinance.com/$1?ref=refinancehotel.com",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "refinancingahotel.com"
        }
      ],
      "destination": "https://hotelloanrefinance.com/$1?ref=refinancingahotel.com",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "refinancehotelloan.com"
        }
      ],
      "destination": "https://hotelloanrefinance.com/$1?ref=refinancehotelloan.com",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        }
      ]
    }
  ]
}
